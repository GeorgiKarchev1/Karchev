NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=

# Admin panel auth — BOTH are required for the admin area to work.
# ADMIN_SECRET must be a long random string (>= 16 chars). It signs session
# tokens; if it is unset/weak/default the admin area fails closed (locked).
# Rotating it instantly invalidates every active admin session.
# Generate one with:  openssl rand -base64 32
ADMIN_SECRET=
ADMIN_PASSWORD=

# Admin analytics & SEO dashboard (Google service account).
# 1) Create a service account in Google Cloud, download its JSON key.
# 2) Enable "Google Analytics Data API" and "Search Console API".
# 3) GA4 → Property Access → add the service account email as Viewer.
# 4) Search Console → Settings → Users → add the service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GA4_PROPERTY_ID=          # numeric GA4 property id (NOT the G-XXXXXXX tag)
GSC_SITE_URL=             # e.g. sc-domain:karchev.xyz  or  https://karchev.xyz/
